/dts-v1/;
#include "exynos5420-galaxy-tab-pro-common.dtsi"

/ {
	model = "Samsung Galaxy Note Pro 12.2 WiFi based on Exynos5420";
	compatible = "samsung,v1a-wifi", "samsung,exynos5420", \
			"samsung,exynos5";

	memory@20000000 {
		device_type = "memory";
		reg = <0x20000000 0xbfa00000>;
	};
	
	i2c_backlight: i2c-24 {
		compatible = "i2c-gpio";
		pinctrl-names = "default";
		pinctrl-0 = <&i2c24_gpio_bus>;
		sda-gpios = <&gpa2 4 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
		scl-gpios = <&gpa2 5 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
		i2c-gpio,delay-us = <2>;

		#address-cells = <1>;
		#size-cells = <0>;

		backlight: backlight@2c {
			compatible = "ti,lp8556";
			reg = <0x2c>;

			bl-name = "lcd-bl";
			dev-ctrl = /bits/ 8 <0x80>;
			init-brt = /bits/ 8 <0x80>;	/* 128 */

			pwms = <&pwm 0 100000 0>;
			pwm-names = "lp8556";
			pinctrl-names = "default";
			pinctrl-0 = <&pwm0_out>;

			enable-supply = <&backlight_reset_supply>;

			/* higher inductor current limit */
			rom-98h {
				rom-addr = /bits/ 8 <0x98>;
				rom-val = /bits/ 8 <0xa1>;
			};

			/* automatic standby via pwm disabled, 25 mA max LED current */
			rom-a1h {
				rom-addr = /bits/ 8 <0xa1>;
				rom-val = /bits/ 8 <0x5f>;
			};

			/* 200 ms slope, heavy smoothing, 1-bit PWM input hysteresis */
			rom-a3h {
				rom-addr = /bits/ 8 <0xa3>;
				rom-val = /bits/ 8 <0x5e>;
			};

			/* disable PWM passthrough, 6 PWM output phases, 9616 Hz PWM frequency */
			rom-a5h {
				rom-addr = /bits/ 8 <0xa5>;
				rom-val = /bits/ 8 <0x04>;
			};

			/* all reserved */
			rom-a8h {
				rom-addr = /bits/ 8 <0xa8>;
				rom-val = /bits/ 8 <0x00>;
			};

			/* 24 V max output voltage, jump detection on pwm input disabled */
			rom-a9h {
				rom-addr = /bits/ 8 <0xa9>;
				rom-val = /bits/ 8 <0xa0>;
			};
		};
	};
};

&ldo24_reg {
	regulator-name = "cam_sensor_core_1v2";
	regulator-min-microvolt = <1050000>;
	regulator-max-microvolt = <1200000>;
};

&ldo26_reg {
	regulator-name = "usb_3.0_drv_3v3";
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
};

&ldo34_reg {
	regulator-name = "vcc_sensor_2v8";
	regulator-min-microvolt = <2800000>;
	regulator-max-microvolt = <2800000>;
	regulator-always-on;
};

&ldo35_reg {
	/* Not defined, something with 1.1V */
	regulator-name = "vdd_ldo35";
	regulator-min-microvolt = <1100000>;
	regulator-max-microvolt = <1100000>;
};

&mmc_1 {
	sd-uhs-sdr104;
};

&mmc_2 {
	sd-uhs-sdr104;
};

&wifi {
	compatible = "brcm,bcm4354-fmac", "brcm,bcm4329-fmac";
};

&panel {
	compatible = "samsung,lsl122dl01";
};

&pinctrl_3 {
	i2c24_gpio_bus: i2c24-gpio-bus-pins {
		samsung,pins = "gpa2-4", "gpa2-5";
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
		samsung,pin-drv = <EXYNOS5420_PIN_DRV_LV1>;
	};
};
