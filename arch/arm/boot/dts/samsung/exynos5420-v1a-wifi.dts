/dts-v1/;
#include "exynos5420-galaxy-tab-pro-common.dtsi"

/ {
	model = "Samsung Galaxy Note Pro 12.2 WiFi based on Exynos5420";
	compatible = "samsung,v1a-wifi", "samsung,exynos5420", \
			"samsung,exynos5";

	memory@20000000 {
		device_type = "memory";
		reg = <0x20000000 0xbfa00000>;
	};

	i2c_backlight: i2c-24 {
		compatible = "i2c-gpio";
		pinctrl-names = "default";
		pinctrl-0 = <&i2c24_gpio_bus>;
		sda-gpios = <&gpa2 4 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
		scl-gpios = <&gpa2 5 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
		i2c-gpio,delay-us = <2>;

		#address-cells = <1>;
		#size-cells = <0>;

		backlight: backlight@2c {
			compatible = "ti,lp8556";
			reg = <0x2c>;

			bl-name = "lcd-bl";
			dev-ctrl = /bits/ 8 <0x80>;
			init-brt = /bits/ 8 <0x80>;	/* 128 */

			pwms = <&pwm 0 100000 0>;
			pwm-names = "lp8556";
			pinctrl-names = "default";
			pinctrl-0 = <&pwm0_out>;

			enable-supply = <&backlight_reset_supply>;

			/* higher inductor current limit */
			rom-98h {
				rom-addr = /bits/ 8 <0x98>;
				rom-val = /bits/ 8 <0xa1>;
			};

			/* automatic standby via pwm disabled, 25 mA max LED current */
			rom-a1h {
				rom-addr = /bits/ 8 <0xa1>;
				rom-val = /bits/ 8 <0x5f>;
			};

			/* 200 ms slope, heavy smoothing, 1-bit PWM input hysteresis */
			rom-a3h {
				rom-addr = /bits/ 8 <0xa3>;
				rom-val = /bits/ 8 <0x5e>;
			};

			/* disable PWM passthrough, 6 PWM output phases, 9616 Hz PWM frequency */
			rom-a5h {
				rom-addr = /bits/ 8 <0xa5>;
				rom-val = /bits/ 8 <0x04>;
			};

			/* all reserved */
			rom-a8h {
				rom-addr = /bits/ 8 <0xa8>;
				rom-val = /bits/ 8 <0x00>;
			};

			/* 24 V max output voltage, jump detection on pwm input disabled */
			rom-a9h {
				rom-addr = /bits/ 8 <0xa9>;
				rom-val = /bits/ 8 <0xa0>;
			};
		};
	};

	tsp_sw3_2v8: tsp-sw3-2v8 {
		compatible = "regulator-fixed";
		regulator-name = "tsp_sw3_2v8";
		regulator-min-microvolt = <2800000>;
		regulator-max-microvolt = <2800000>;
		pinctrl-names = "default";
		pinctrl-0 = <&touch_en1>;
		gpio = <&gpx1 6 GPIO_ACTIVE_HIGH>;
		startup-delay-us = <1000>;
		enable-active-high;
		vin-supply = <&ldo29_reg>;
	};

	touch_avdd_2v8: touch-avdd-2v8 {
		compatible = "regulator-fixed";
		regulator-name = "touch_avdd_2v8";
		regulator-min-microvolt = <2800000>;
		regulator-max-microvolt = <2800000>;
		pinctrl-names = "default";
		pinctrl-0 = <&touch_en>;
		gpio = <&gpx0 6 GPIO_ACTIVE_HIGH>;
		startup-delay-us = <30000>;
		enable-active-high;
		vin-supply = <&tsp_sw3_2v8>;
	};

	stylus_reg: stylus-regulator {
		compatible = "regulator-fixed";
		regulator-name = "stylus_reg";
		pinctrl-names = "default";
		pinctrl-0 = <&stylus_ldo_en>;
		gpio = <&gpd1 4 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		vin-supply = <&ldo3_reg>;
	};
};

&accelerometer {
	vdd-supply = <&ldo34_reg>;
};

&gyroscope {
	vdd-supply = <&ldo34_reg>;
};

&i2c_0 {
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	touchscreen@4a {
		compatible = "atmel,maxtouch";
		reg = <0x4a>;
		pinctrl-names = "default";
		pinctrl-0 = <&touch_reset &touch_chg>;
		interrupt-parent = <&gpd1>;
		interrupts = <0 IRQ_TYPE_EDGE_FALLING>;
		reset-gpios = <&gpy7 4 GPIO_ACTIVE_LOW>;
		vdda-supply = <&touch_avdd_2v8>;
		vdd-supply = <&ldo29_reg>;
	};
};

&hsi2c_8 {
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	digitizer@56 {
		compatible = "wacom,w9007a_v1";
		reg = <0x56>;
		pinctrl-names = "default";
		pinctrl-0 = <&stylus_pdct &stylus_fwe &stylus_insert &stylus_irq>;
		interrupt-parent = <&gpx3>;
		interrupts = <5 IRQ_TYPE_EDGE_RISING>;

		vdd-supply = <&stylus_reg>;

		pdct-gpios = <&gpd1 2 GPIO_ACTIVE_LOW>;
		flash-mode-gpios = <&gpd1 3 GPIO_ACTIVE_HIGH>;
		pen-inserted-gpios = <&gpx0 0 GPIO_ACTIVE_LOW>;

		touchscreen-x-mm = <262>;
		touchscreen-y-mm = <164>;
	};
};

&ldo24_reg {
	regulator-name = "cam_sensor_core_1v2";
	regulator-min-microvolt = <1050000>;
	regulator-max-microvolt = <1200000>;
};

&ldo26_reg {
	regulator-name = "usb_3.0_drv_3v3";
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
};

&ldo34_reg {
	regulator-name = "vcc_sensor_2v8";
	regulator-min-microvolt = <2800000>;
	regulator-max-microvolt = <2800000>;
	regulator-always-on;	// needed because light-sensor doesn't support supply
};

&ldo35_reg {
	/* Not defined, something with 1.1V */
	regulator-name = "vdd_ldo35";
	regulator-min-microvolt = <1100000>;
	regulator-max-microvolt = <1100000>;
};

&magnetometer {
	vdd-supply = <&ldo34_reg>;
};

&mmc_1 {
	sd-uhs-sdr104;
};

&mmc_2 {
	sd-uhs-sdr104;
};

&wifi {
	compatible = "brcm,bcm4354-fmac", "brcm,bcm4329-fmac";
};

&panel {
	compatible = "samsung,lsl122dl01";
};

&pinctrl_0 {
	stylus_insert: stylus-insert-pins {
		samsung,pins = "gpx0-0";
		samsung,pin-function = <EXYNOS_PIN_FUNC_F>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
	};

	touch_en: toch-en-pins {
		samsung,pins = "gpx0-6";
		samsung,pin-function = <EXYNOS_PIN_FUNC_OUTPUT>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
		samsung,pin-drv = <EXYNOS5420_PIN_DRV_LV1>;
	};

	touch_en1: toch-en1-pins {
		samsung,pins = "gpx1-6";
		samsung,pin-function = <EXYNOS_PIN_FUNC_OUTPUT>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
		samsung,pin-drv = <EXYNOS5420_PIN_DRV_LV1>;
	};

	stylus_irq: stylus-irq-pins {
		samsung,pins = "gpx3-5";
		samsung,pin-function = <EXYNOS_PIN_FUNC_F>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
	};

	touch_reset: touch-reset-pins {
		samsung,pins = "gpy7-4";
		samsung,pin-function = <EXYNOS_PIN_FUNC_OUTPUT>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
		samsung,pin-drv = <EXYNOS5420_PIN_DRV_LV1>;
	};
};

&pinctrl_1 {
	touch_chg: toch-chg-pins {
		samsung,pins = "gpd1-0";
		samsung,pin-function = <EXYNOS_PIN_FUNC_F>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
	};

	stylus_pdct: stylus-pdct-pins {
		samsung,pins = "gpd1-2";
		samsung,pin-function = <EXYNOS_PIN_FUNC_F>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
	};

	stylus_fwe: stylus-fwe-pins {
		samsung,pins = "gpd1-3";
		samsung,pin-function = <EXYNOS_PIN_FUNC_OUTPUT>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
		samsung,pin-drv = <EXYNOS5420_PIN_DRV_LV1>;
	};

	stylus_ldo_en: stylus-ldo-en-pins {
		samsung,pins = "gpd1-4";
		samsung,pin-function = <EXYNOS_PIN_FUNC_OUTPUT>;
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
		samsung,pin-drv = <EXYNOS5420_PIN_DRV_LV1>;
	};
};

&pinctrl_3 {
	i2c24_gpio_bus: i2c24-gpio-bus-pins {
		samsung,pins = "gpa2-4", "gpa2-5";
		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
		samsung,pin-drv = <EXYNOS5420_PIN_DRV_LV1>;
	};
};
